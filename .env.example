# Copy this file to .env and fill in your actual keys
# Never commit .env to version control

# LLM Provider: Groq (free, fast — used for intent classification and response generation)
GROQ_API_KEY=your_groq_api_key_here

# Embedding model is local (all-MiniLM-L6-v2) — no API key needed.

# Optional: override paths if running outside project root
# CATALOG_PATH=data/shl_product_catalog.json
# INDEX_PATH=embeddings/faiss_index/
